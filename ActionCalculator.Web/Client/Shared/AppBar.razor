<MudAppBar Dense="true" Elevation="1" Style="position: relative;">
    <span class="appbar-title">Dave's Action Calculator</span>
    
    <MudIconButton Href="/" Icon="fa-solid fa-calculator" Color="Color.Inherit" Title="Calculator"/>
    <MudIconButton Href="/advanced" Icon="fa-solid fa-gears" Color="Color.Inherit" Title="Advanced"/>
    <MudIconButton Href="/glossary" Icon="@Icons.Material.Filled.ListAlt" Color="Color.Inherit" Title="Glossary"/>
    <MudIconButton Href="/faq" Icon="@Icons.Material.Filled.QuestionAnswer" Color="Color.Inherit" Title="FAQ"/>
    <MudIconButton Href="/about" Icon="@Icons.Material.Filled.Info" Color="Color.Inherit" Title="About"/>

    <MudSelect T="string" Value="_season" ValueChanged="SeasonChanged"
               Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
               Class="season-select"
               AnchorOrigin="Origin.BottomCenter">
        <MudSelectItem Value="@("Season 2")">Season 2</MudSelectItem>
        <MudSelectItem Value="@("Season 3")">Season 3</MudSelectItem>
    </MudSelect>

    <MudSpacer/>

    @if (_isLightMode)
    {
        <MudIconButton Icon="@Icons.Material.Filled.Brightness4" Color="Color.Inherit" OnClick="ToggleTheme"/>
    }
    else
    {
        <MudIconButton Icon="@Icons.Material.Filled.Brightness5" Color="Color.Inherit" OnClick="ToggleTheme"/>
    }
</MudAppBar>