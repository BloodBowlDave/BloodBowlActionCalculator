
<MudItem Class="action-summary">
    <MudPaper Style="min-height: 51px; overflow: visible;">

        <h6 @onclick="() => RemoveActionByIndex(Index)">
            @if (PlayerAction.RequiresNonCriticalFailure && Action.ActionType == ActionType.Block)
            {
                @("Frenzy - ")
            }
            else if (Action.ActionType == ActionType.Block)
            {
                if (LastActionType == ActionType.Dauntless)
                {
                    @("Dauntless Success - ")
                }

                if (PenultimateActionType == ActionType.Dauntless)
                {
                    @("Dauntless Failure - ")
                }
            }

            @(Action.GetDescription())
            @if (PlayerAction.RequiresNonCriticalFailure && Action.ActionType == ActionType.Block)
            {
                <MudTooltip Text="Triggered on a push result">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"/>
                </MudTooltip>
            }
            <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small"/>
        </h6>

        @if (Action.ActionType == ActionType.Block)
        {
            <div class="dice-select">
                <MudSelect T="int" Label="Dice" Dense="true" Variant="Variant.Text" AnchorOrigin="Origin.BottomLeft"
                           Value="((Models.Actions.Block)Action).NumberOfDice"
                           ValueChanged="FrenzyDiceChanged">
                    <MudSelectItem T="int" Value="-3">1/3 Dice</MudSelectItem>
                    <MudSelectItem T="int" Value="-2">1/2 Dice</MudSelectItem>
                    <MudSelectItem T="int" Value="1">1 Die</MudSelectItem>
                    <MudSelectItem T="int" Value="2">2 Dice</MudSelectItem>
                    <MudSelectItem T="int" Value="3">3 Dice</MudSelectItem>
                </MudSelect>
            </div>

            <MudNumericField T="int" Min="1" Max="@BlockSuccessesMax()"
                             Value="((Models.Actions.Block)PlayerAction.Action).NumberOfSuccessfulResults"
                             ValueChanged="SuccessesChanged"
                             Label="Successes"/>

            if (!PlayerAction.RequiresNonCriticalFailure)
            {
                <MudNumericField T="int" Min="0" Max="@(5 - ((Models.Actions.Block)Action).NumberOfSuccessfulResults)"
                                 Value="((Models.Actions.Block)Action).NumberOfNonCriticalFailures"
                                 ValueChanged="PushesChanged"
                                 Label="Pushes"/>
            }
        }

        @{
            var options = GetActionOptions().ToList();
        }
        @if (options.Any())
        {
            <MudSelect T="string"
                       MultiSelection="true"
                       SelectedValues="@GetSelectedOptions()"
                       SelectedValuesChanged="@((IReadOnlyCollection<string> values) => OptionsChanged(values))"
                       MultiSelectionTextFunc="@(items => items.Count == 0 ? string.Empty : string.Join(", ", items))"
                       Dense="true"
                       Label="Overrides"
                       Variant="Variant.Text"
                       AnchorOrigin="Origin.BottomLeft">
                @foreach (var option in options)
                {
                    <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                }
            </MudSelect>
        }
    </MudPaper>
</MudItem>
