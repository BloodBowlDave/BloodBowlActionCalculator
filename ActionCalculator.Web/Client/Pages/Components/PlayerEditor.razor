@using ActionCalculator.Utilities
@using System.Linq

<MudPaper Class="player-editor">

    <h4>
        Player @(PlayerNumber.ToString())
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" OnClick="ClearSelected">Clear</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Tertiary" Size="Size.Small" OnClick="NewPlayer">New</MudButton>
    </h4>

    <div class="player-skills-row">
        <MudSelect T="CalculatorSkills"
                   MultiSelection="true"
                   SelectedValues="SelectedSkills"
                   SelectedValuesChanged="SkillsChanged"
                   Label="Skills"
                   Variant="Variant.Outlined"
                   Dense="true"
                   AnchorOrigin="Origin.BottomCenter"
                   Style="width: 240px"
                   MultiSelectionTextFunc="@(selected => selected.Count == 0 ? "None" : string.Join(", ", selected))">
            @foreach (var skill in GetSkills())
            {
                <MudSelectItem T="CalculatorSkills" Value="skill">@skill.ToString().PascalCaseToSpaced()</MudSelectItem>
            }
        </MudSelect>

        @if (CurrentPlayer.CanUseSkill(CalculatorSkills.Loner, CalculatorSkills.None))
        {
            <div class="skill-value-row">
                <span>Loner</span>
                <MudNumericField T="int" Min="2" Max="6"
                                 Value="CurrentPlayer.LonerValue"
                                 ValueChanged="@LonerChanged" />
            </div>
        }
        @if (CurrentPlayer.CanUseSkill(CalculatorSkills.MightyBlow, CalculatorSkills.None))
        {
            <div class="skill-value-row">
                <span>Mighty Blow</span>
                <MudNumericField T="int" Min="1" Max="2"
                                 Value="CurrentPlayer.MightyBlowValue"
                                 ValueChanged="@MightyBlowChanged" />
            </div>
        }
        @if (CurrentPlayer.CanUseSkill(CalculatorSkills.DirtyPlayer, CalculatorSkills.None))
        {
            <div class="skill-value-row">
                <span>Dirty Player</span>
                <MudNumericField T="int" Min="1" Max="2"
                                 Value="CurrentPlayer.DirtyPlayerValue"
                                 ValueChanged="@DirtyPlayerChanged" />
            </div>
        }
        @if (CurrentPlayer.CanUseSkill(CalculatorSkills.BreakTackle, CalculatorSkills.None))
        {
            <div class="skill-value-row">
                <span>Break Tackle</span>
                <MudNumericField T="int" Min="1" Max="@(Season == "Season 2" ? 2 : 3)"
                                 Value="CurrentPlayer.BreakTackleValue"
                                 ValueChanged="@BreakTackleChanged" />
            </div>
        }
    </div>

</MudPaper>
